outputs/*
!outputs/.gitkeep
!outputs/figures/
!outputs/logs/
outputs/figures/*
!outputs/figures/.gitkeep
outputs/logs/*
!outputs/logs/.gitkeep

# Collab report artifacts: keep folder only
reportCollab/*
!reportCollab/.gitkeep

# Reports artifacts: keep folder only (except optional readme)
reports/*
!reports/.gitkeep
!reports/README.md
